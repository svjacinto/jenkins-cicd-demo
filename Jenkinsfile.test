pipeline{
    agent {
        label 'agent-1'
    }

    options {
        timestamps()
        disableConcurrentBuilds(abortPrevious: true)
        buildDiscarder(logRotator(numToKeepStr: '20'))
    }

    environment {
        APP_NAME = 'jenkins-cicd-demo'
        IMAGE_NAME = 'jenkins-cicd-demo'
    }

    stages {
        stage('Show Agent Info') {
            steps {
                echo "Running on node: ${env.NODE_NAME}"
                echo "Workspace: ${env.WORKSPACE}"
                echo "EXECUTOR_NUMBER: ${env.EXECUTOR_NUMBER}"

                sh '''
                echo "Hostname: $(hostname)"
                echo "User: $(whoami)"
                echo "Current directory: $(pwd)"
                
                echo "Java:"
                java -version || true

                echo "Node:"
                node -v || true

                echo "npm:"
                npm -v || true

                echo "Docker:"
                docker --version || true
                '''
            }
        }

        stage('CI - Checkout') {
            steps {
                deleteDir()
                cleanWs()
                checkout scm

                script {
                    env.SHORT_COMMIT = env.GIT_COMMIT ? env.GIT_COMMIT.take(7) : 'local'
                    env.IMAGE_TAG = "${env.BUILD_NUMBER}-${env.SHORT_COMMIT}"
                }

                echo "IMAGE_TAG: ${env.IMAGE_TAG}"
            }
        }

        stage('CI - Install dependencies') {
            steps {
                sh '''
                    npm ci
                    npm install -g snyk
                    npm install
                '''
            }
        }

        stage('CI - Secret Scan') {
            steps {
                sh '''
                    if command -v gitleaks >/dev/null 2>&1; then
                        echo "Running Secret Scan using Gitleaks..."

                        gitleaks detect \
                            --source . \
                            --report-format json \
                            --report-path gitleaks-report.json \
                            --redact \
                            --exit-code 1
                    else
                        echo "Gitleaks is not installed."
                    fi
                '''
                archiveArtifacts artifacts: 'gitleaks-report.json', fingerprint: true
            }
        }

        stage('CI - SAST') {
            steps {
                sh '''
                    if command -v semgrep >/dev/null 2>&1; then
                        semgrep scan --config auto --json --output semgrep-report.json . || true
                    else
                        echo "Semgrep is not installed."
                        echo '{"results":[]}' > semgrep-report.json
                    fi
                '''
                archiveArtifacts artifacts: 'semgrep-report.json', fingerprint: true
            }

            script {
                def report = readJSON file: 'semgrep-report.json'

                def findings = report.results ?: []

                def summary = ""
                summary += "Tool: Semgrep\n"
                summary += "Findings: ${findings.size()}\n\n"

                findings.take(10).each { finding ->
                    def severity = finding.extra?.severity ?: 'UNKNOWN'
                    def message = finding.extra?.message ?: 'No message'
                    def path = finding.path ?: 'Unknown file'
                    def line = finding.start?.line ?: '?'
                    def ruleId = finding.check_id ?: 'Unknown rule'

                    summary += "- ${severity}: ${ruleId}\n"
                    summary += "  ${message}\n"
                    summary += "  File: ${path}:${line}\n\n"
                }

                if (findings.size() > 10) {
                    summary += "\n...and ${findings.size() - 10} more."
                }

                publishChecks(
                    name: 'Semgrep SAST',
                    title: 'Static Application Security Testing',
                    summary: summary.toString(),
                    conclusion: findings.isEmpty() ? 'SUCCESS' : 'FAILURE',
                    detailsURL: env.BUILD_URL
                )

                if (!findings.isEmpty()) {
                    error "Semgrep found ${findings.size()} SAST finding(s)."
                }
            }
        }

        stage('CI - Generate SBOM') {
            steps {
                sh '''
                    echo "Generating SBOM using Trivy..."
                    trivy fs --format cyclonedx --output sbom.json .
                '''
                archiveArtifacts artifacts: 'sbom.json', fingerprint: true
            }
        }

    }
}